<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.croftonix.Cronix</id>
  <name>Cronix</name>
  <summary>Lightweight privacy-respecting browser by Croftonix</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>MIT</project_license>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/james15-spec/Cronix-browser/main/screenshots/cronix-home.png</image>
      <caption>Cronix home page</caption>
    </screenshot>
  </screenshots>

  <description>
    <p>
      Cronix is a lightweight desktop web browser built with PyQt6 and
      QtWebEngine. It focuses on simplicity, privacy, and user control —
      no telemetry, no ads, no accounts required.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Tabbed browsing with favicons and animated loading spinner</li>
      <li>Built-in password manager with local encryption</li>
      <li>Browsing history viewer with search</li>
      <li>Download manager with progress tracking</li>
      <li>Cookie manager</li>
      <li>Session restore</li>
      <li>Screenshot tool with clipboard support</li>
      <li>Find in page, zoom controls, and mute tabs</li>
      <li>Dark and light themes with accent colour selection</li>
    </ul>
  </description>

  <launchable type="desktop-id">org.croftonix.Cronix.desktop</launchable>

  <url type="homepage">https://github.com/james15-spec/Cronix-browser</url>
  <url type="bugtracker">https://github.com/james15-spec/Cronix-browser/issues</url>

